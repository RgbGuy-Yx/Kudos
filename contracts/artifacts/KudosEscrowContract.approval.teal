    bz approve_milestone_after_if_else@7
    // kudos_escrow_contract.py:133
    // self.status.value = UInt64(2)
    bytec_3 // "status"
    intc_3 // 2
    app_global_put

approve_milestone_after_if_else@7:
    // kudos_escrow_contract.py:102
    // @arc4.abimethod()
    intc_1 // 1
    return

approve_milestone_else_body@3:
