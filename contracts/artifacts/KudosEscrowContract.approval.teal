    app_global_get_ex
    assert // check self.student exists
    itxn_field Receiver
    itxn_field Amount
    // kudos_escrow_contract.py:124
    // itxn.Payment(
    intc_1 // pay
    itxn_field TypeEnum
    // kudos_escrow_contract.py:127
    // fee=0,
    intc_0 // 0
