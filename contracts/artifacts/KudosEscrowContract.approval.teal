    assert // check self.milestone_index exists
    intc_0 // 0
    bytec_2 // "milestone_count"
    app_global_get_ex
    assert // check self.milestone_count exists
    <
    assert // All milestones already approved
    // kudos_escrow_contract.py:113
    // base_payout = self._base_payout()
    callsub _base_payout
    // kudos_escrow_contract.py:115-116
    // # Final milestone receives all remaining escrow to avoid rounding loss.
    // remaining_milestones = self.milestone_count.value - self.milestone_index.value
    intc_0 // 0
    bytec_2 // "milestone_count"
    app_global_get_ex
    assert // check self.milestone_count exists
    intc_0 // 0
    bytec_0 // "milestone_index"
    app_global_get_ex
    assert // check self.milestone_index exists
    -
    // kudos_escrow_contract.py:117
    // if remaining_milestones == UInt64(1):
    intc_1 // 1
    ==
    bz approve_milestone_else_body@3
    // kudos_escrow_contract.py:118
    // payout = self._remaining_escrow()
    callsub _remaining_escrow

approve_milestone_after_if_else@4:
    // kudos_escrow_contract.py:122
