    assert // check self.sponsor exists
    ==
    assert // Only sponsor can approve
    // kudos_escrow_contract.py:110
    // assert self.status.value == UInt64(1), "Grant not active"
    intc_0 // 0
    bytec_3 // "status"
    app_global_get_ex
    assert // check self.status exists
    intc_1 // 1
    ==
    assert // Grant not active
    // kudos_escrow_contract.py:111
    // assert self.milestone_index.value < self.milestone_count.value, "All milestones already approved"
    intc_0 // 0
    bytec_0 // "milestone_index"
